# ─────────────────────────────────────────────────────────────
# MeinAppNest — Beispiel-Umgebung. NUR Platzhalter.
# Echte Werte liefert der Betreiber lokal / als K8s-Secret.
# Diese Datei IST eingecheckt; eine echte .env NIEMALS committen.
# ─────────────────────────────────────────────────────────────

# ── Storefront (apps/storefront) ─────────────────────────────
NEXT_PUBLIC_APP_URL=https://store.meinappnest.org
CONTROL_PLANE_URL=http://control-plane.dynstore.svc.cluster.local:8080
AUTH_SECRET=__CHANGE_ME__                      # Session/JWT-Signatur

# ── Control-Plane (services/control-plane) ───────────────────
PORT=8080
DATABASE_URL=postgresql://dynstore:__CHANGE_ME__@postgres:5432/dynstore?schema=public
CP_SERVICE_TOKEN=__CHANGE_ME__                 # Storefront -> Control-Plane

# ── Stripe (NICHT committen) ─────────────────────────────────
STRIPE_SECRET_KEY=sk_test___CHANGE_ME__
STRIPE_WEBHOOK_SECRET=whsec___CHANGE_ME__
STRIPE_PORTAL_RETURN_URL=https://store.meinappnest.org/dashboard

# ── GitOps (Control-Plane committet HelmReleases) ────────────
GITOPS_REPO_URL=git@github.com:__ORG__/dynstore.git
GITOPS_REPO_BRANCH=main
GITOPS_TENANTS_PATH=platform/tenants
GIT_AUTHOR_NAME=dynstore-control-plane
[email protected]

# ── Kubernetes (nur falls direkter API-Zugriff im MVP) ───────
KUBECONFIG=/var/run/secrets/dynstore/kubeconfig

# ── Tenant-Defaults ──────────────────────────────────────────
APPS_BASE_DOMAIN=meinappnest.org
DEPROVISION_GRACE_DAYS=14

# ── dynDNSv4 (DNS + ACME-DNS-01) ─────────────────────────────
DNS_MODE=wildcard-per-app                 # wildcard-per-app | per-tenant | none
DYNDNS_API_BASE=https://panel.dyndnsv4.de
DYNDNS_USERNAME=__CHANGE_ME__             # dynDNSv4 Account-E-Mail
DYNDNS_TOKEN=__CHANGE_ME__                # dynDNSv4 Token (NICHT committen)
LB_IPV4=91.98.1.85
# LB_IPV6=
